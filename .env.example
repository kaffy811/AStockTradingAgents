# ── TradingAgents — Root .env.example ────────────────────────────────────────
# This file is the single source of truth for all docker compose environment
# variables.  Copy it to .env and fill in real values before running:
#
#   cp .env.example .env
#   docker compose up --build
#
# NEVER commit .env to version control.
# .env is already listed in .gitignore.

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=TradingAgents Backend
APP_ENV=production
DEBUG=false

# ── Schema management ─────────────────────────────────────────────────────────
# false  → production mode: skip create_all, rely on Alembic migrations.
# true   → dev fallback: create_all at every startup (safe no-op for existing tables).
# Production first-deploy: docker compose exec backend uv run alembic upgrade head
ENABLE_CREATE_ALL=false

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase PostgreSQL — Transaction Pooler URL (port 6543).
# Format: postgresql+asyncpg://<user>:<password>@<host>:6543/<db>
# The backend uses NullPool + statement_cache_size=0 for PgBouncer compatibility.
DATABASE_URL=postgresql+asyncpg://user:password@host:6543/postgres

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Minimum 16 characters. 64 characters recommended for production.
SECRET_KEY=change-this-to-a-random-64-char-string

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Redis ─────────────────────────────────────────────────────────────────────
# docker compose: always redis://redis:6379 (the compose service name).
# Overridden in docker-compose.yml environment block, so this value is a
# fallback for local dev without Docker.
REDIS_URL=redis://redis:6379

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Leave blank if not using OpenAI
OPENAI_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# MUST be a JSON array.  Comma-separated strings will cause a startup crash.
#
# With Nginx reverse-proxy (VITE_API_BASE=/api/v1): browser uses same origin,
# so CORS is not enforced by browsers.  Still set a real value instead of "*".
#
# Correct:   CORS_ORIGINS=["https://yourdomain.com","http://localhost"]
# WRONG:     CORS_ORIGINS=https://yourdomain.com,http://localhost
CORS_ORIGINS=["http://localhost","https://yourdomain.com"]
