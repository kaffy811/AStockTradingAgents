# ── TradingAgents Backend — Environment Variables ───────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=TradingAgents Backend
APP_ENV=production
DEBUG=false

# ── Schema management ─────────────────────────────────────────────────────────
# Set to false in production to skip Base.metadata.create_all at startup.
# Production workflow:
#   First deploy:  docker compose exec backend uv run alembic upgrade head
#   Later changes: docker compose exec backend uv run alembic upgrade head
# If the DB was created by create_all before Alembic was introduced:
#   docker compose exec backend uv run alembic stamp head  (one-time)
ENABLE_CREATE_ALL=false

# ── Database ─────────────────────────────────────────────────────────────────
# Supabase PostgreSQL — use the Transaction Pooler URL (port 6543, not 5432).
# The connection string must use the asyncpg driver prefix:
#   postgresql+asyncpg://<user>:<password>@<host>:6543/<db>
# The backend uses NullPool + statement_cache_size=0 for PgBouncer compatibility.
# Do NOT switch to Session Pooler (port 5432) under concurrent load.
DATABASE_URL=postgresql+asyncpg://user:password@host:6543/postgres

# ── Authentication ────────────────────────────────────────────────────────────
# JWT signing key. Must be at least 16 characters.
# For production, generate a 64-character random string:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-string

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Redis ────────────────────────────────────────────────────────────────────
# Docker Compose: use the service name "redis" as host.
# Local dev without Docker: redis://localhost:6379
# Redis is optional — if unavailable the backend degrades gracefully (no cache).
REDIS_URL=redis://redis:6379

# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=deepseek

DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Leave blank if not using OpenAI
OPENAI_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
# IMPORTANT: value must be a valid JSON array, NOT a comma-separated string.
# When using the Nginx reverse-proxy setup (VITE_API_BASE=/api/v1), the browser
# makes same-origin requests through Nginx so CORS headers are not strictly
# required. Still prefer an explicit allow-list over "*" in production.
#
# Correct:   CORS_ORIGINS=["https://yourdomain.com","http://localhost"]
# WRONG:     CORS_ORIGINS=https://yourdomain.com,http://localhost  ← will crash
CORS_ORIGINS=["http://localhost","https://yourdomain.com"]
