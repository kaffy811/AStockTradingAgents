# ── Secrets & local config ──────────────────────────────────────────────────
.env
.env.*

# ── Virtual environments ────────────────────────────────────────────────────
.venv/
venv/

# ── Python bytecode ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# ── Test / lint caches ───────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── Dev & admin scripts (not needed at runtime) ──────────────────────────────
scripts/

# ── Probe / temporary data outputs ──────────────────────────────────────────
app/data/probe_outputs/

# ── Docs (not needed inside the container) ──────────────────────────────────
docs/
README.md

# ── OS / IDE noise ───────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore
