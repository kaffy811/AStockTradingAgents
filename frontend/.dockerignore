# ── Node modules — always rebuilt inside the container ───────────────────────
node_modules/

# ── Previous build output — rebuilt inside the container ─────────────────────
dist/

# ── Local environment files — never include secrets in the image ─────────────
.env
.env.local
.env.development
.env.development.local
.env.production.local

# ── Debug logs ────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / IDE noise ────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore
