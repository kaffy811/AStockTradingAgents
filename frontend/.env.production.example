# ── TradingAgents Frontend — Production Environment Variables ────────────────
# Copy this file to .env.production for local production builds.
# When building inside Docker, VITE_API_BASE is injected via the Dockerfile ARG
# (default /api/v1), so you do NOT need .env.production inside the container.
#
# Docker / Nginx deployment (recommended):
#   Use the relative path /api/v1.
#   Nginx proxies /api/v1/* → backend:8000, so the browser makes same-origin
#   requests — no CORS headers needed, no domain name baked into the bundle.
#
# Direct-to-backend deployment (not recommended):
#   VITE_API_BASE=https://api.yourdomain.com/api/v1
#   Requires explicit CORS_ORIGINS on the backend and rebuilds when domain changes.
#
# WARNING: This variable is baked into the JS bundle at build time by Vite.
#   Changing it after build has NO effect. You must rebuild the image.

VITE_API_BASE=/api/v1
